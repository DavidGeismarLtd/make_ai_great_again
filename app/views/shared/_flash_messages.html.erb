<%# Flash Messages %>
<%# Displays Bootstrap alerts for success, error, notice, and alert messages %>

<% if flash.any? %>
  <div class="container-fluid mt-3" id="flash-messages">
    <% flash.each do |type, message| %>
      <div class="alert alert-<%= bootstrap_class_for(type) %> alert-dismissible fade show" role="alert">
        <%= message %>
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
      </div>
    <% end %>
  </div>
<% end %>

