<%# User Menu Dropdown %>
<%# Shows user avatar/initials and dropdown menu with profile, settings, sign out %>

<% if user_signed_in? %>
  <div class="dropdown ms-3" data-controller="dropdown">
    <button class="btn btn-link text-decoration-none dropdown-toggle p-0" type="button" id="userMenuDropdown" data-dropdown-target="toggle" data-action="click->dropdown#toggle" aria-expanded="false">
      <div class="user-avatar" style="background-color: <%= user_avatar_color(current_user) %>;">
        <%= user_initials(current_user) %>
      </div>
    </button>
    <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="userMenuDropdown" data-dropdown-target="menu" style="position: absolute; right: 0; left: auto;">
      <li>
        <div class="dropdown-header">
          <div class="fw-bold"><%= current_user.first_name %> <%= current_user.last_name %></div>
          <div class="small text-muted"><%= current_user.email %></div>
        </div>
      </li>
      <li><hr class="dropdown-divider"></li>

      <%# Future: Profile page %>
      <%# <li> %>
      <%#   <%= link_to profile_path, class: "dropdown-item" do %>
      <%#     <i class="bi bi-person me-2"></i> Profile %>
      <%#   <% end %>
      <%# </li> %>

      <li>
        <%= link_to main_app.edit_user_registration_path, class: "dropdown-item" do %>
          <i class="bi bi-gear me-2"></i> Account Settings
        <% end %>
      </li>

      <% if current_organization %>
        <li>
          <h6 class="dropdown-header text-uppercase small">
            <%= current_organization.name %>
          </h6>
        </li>
        <li>
          <%= link_to main_app.org_api_configurations_path(current_organization.slug), class: "dropdown-item" do %>
            <i class="bi bi-key me-2"></i> API Keys
          <% end %>
        </li>
        <li>
          <%= link_to main_app.org_organization_settings_path(current_organization.slug), class: "dropdown-item" do %>
            <i class="bi bi-sliders me-2"></i> Organization Settings
          <% end %>
        </li>
      <% end %>

      <li><hr class="dropdown-divider"></li>

      <li>
        <%= button_to main_app.destroy_user_session_path, method: :delete, class: "dropdown-item text-danger" do %>
          <i class="bi bi-box-arrow-right me-2"></i> Sign Out
        <% end %>
      </li>
    </ul>
  </div>
<% end %>
