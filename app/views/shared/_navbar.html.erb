<%# Unified Navigation Bar %>
<%# Works across host app and AgentsOnRails engine %>
<%# Includes: Logo, Testing, Monitoring, Search, Theme Toggle, Org Switcher, User Menu %>

<nav class="navbar navbar-expand-lg navbar-dark pt-navbar">
  <div class="container-fluid">
    <%# Logo - AgentsOnRails branding %>
    <% if user_signed_in? && current_organization %>
      <%= link_to org_prompt_tracker.root_path(org_slug: current_organization.slug), class: "navbar-brand pt-brand" do %>
        <span class="pt-logo-cursor">&gt;</span>
        <span class="pt-logo-prompt">Agents</span><span class="pt-logo-tracker">OnRails</span>
      <% end %>
    <% else %>
      <%= link_to root_path, class: "navbar-brand pt-brand" do %>
        <span class="pt-logo-cursor">&gt;</span>
        <span class="pt-logo-prompt">Agents</span><span class="pt-logo-tracker">OnRails</span>
      <% end %>
    <% end %>

    <%# Mobile menu toggle %>
    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav" aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
      <span class="navbar-toggler-icon"></span>
    </button>

    <div class="collapse navbar-collapse" id="navbarNav">
      <% if user_signed_in? && current_organization %>
        <%# Main navigation - only show when authenticated and in org context %>
        <ul class="navbar-nav me-auto">
          <%# Testing Section %>
          <li class="nav-item">
            <%= link_to org_prompt_tracker.testing_root_path(org_slug: current_organization.slug), class: "nav-link #{'active' if current_section == 'testing'}" do %>
              <i class="bi bi-check2-square"></i> Testing
            <% end %>
          </li>

          <%# Monitoring Section - Only show if enabled in features %>
          <% if PromptTracker.configuration.feature_enabled?(:monitoring) %>
            <li class="nav-item">
              <%= link_to org_prompt_tracker.monitoring_root_path(org_slug: current_organization.slug), class: "nav-link pt-nav-monitoring #{'active' if current_section == 'monitoring'}" do %>
                <i class="bi bi-activity"></i> Monitoring
              <% end %>
            </li>
          <% end %>

          <%# Functions Section - Only show if enabled in features %>
          <% if PromptTracker.configuration.feature_enabled?(:functions) %>
            <li class="nav-item">
              <%= link_to org_prompt_tracker.functions_path(org_slug: current_organization.slug), class: "nav-link #{'active' if current_section == 'functions'}" do %>
                <i class="bi bi-code-square"></i> Functions
              <% end %>
            </li>
          <% end %>

          <%# Organizations - Future %>
          <%# <li class="nav-item"> %>
          <%#   <%= link_to organizations_path, class: "nav-link #{'active' if current_section == 'organizations'}" do %>
          <%#     <i class="bi bi-building"></i> Organizations %>
          <%#   <% end %>
          <%# </li> %>

          <%# API Keys - Future %>
          <%# <li class="nav-item"> %>
          <%#   <%= link_to "#", class: "nav-link #{'active' if current_section == 'api_keys'}" do %>
          <%#     <i class="bi bi-key"></i> API Keys %>
          <%#   <% end %>
          <%# </li> %>
        </ul>

        <%# Search form - only in PromptTracker context %>
        <% if in_prompt_tracker? %>
          <form class="d-flex" role="search" action="<%= org_prompt_tracker.testing_root_path(org_slug: current_organization.slug) %>" method="get">
            <input class="form-control me-2" type="search" name="q" placeholder="Search prompts..." value="<%= params[:q] %>" aria-label="Search">
            <button class="btn btn-outline-primary" type="submit">
              <i class="bi bi-search"></i>
            </button>
          </form>
        <% end %>

        <%# Theme Toggle %>
        <button class="theme-toggle ms-3" id="themeToggle" title="Toggle theme">
          <i class="bi bi-sun-fill" id="themeIcon"></i>
        </button>

        <%# Organization Switcher %>
        <%= render "shared/organization_switcher" %>

        <%# User Menu %>
        <%= render "shared/user_menu" %>

      <% else %>
        <%# Guest state - not authenticated %>
        <ul class="navbar-nav ms-auto">
          <li class="nav-item">
            <%= link_to "Sign In", main_app.new_user_session_path, class: "nav-link" %>
          </li>
          <li class="nav-item">
            <%= link_to "Sign Up", main_app.new_user_registration_path, class: "btn btn-primary ms-2" %>
          </li>
        </ul>
      <% end %>
    </div>
  </div>
</nav>
