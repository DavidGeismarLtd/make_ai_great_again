<div id="contact-form">
  <%= form_with url: contact_path, method: :post, data: { turbo_frame: "contact-form" } do |f| %>
    <% if local_assigns[:error] %>
      <div class="alert alert-danger mb-3">
        <%= error %>
      </div>
    <% end %>

    <div class="mb-3">
      <%= f.label :name, "Your Name", class: "form-label" %>
      <%= f.text_field :name, class: "form-control", placeholder: "John Doe", required: true %>
    </div>

    <div class="mb-3">
      <%= f.label :email, "Your Email", class: "form-label" %>
      <%= f.email_field :email, class: "form-control", placeholder: "john@example.com", required: true %>
    </div>

    <div class="mb-3">
      <%= f.label :message, "Your Message", class: "form-label" %>
      <%= f.text_area :message, class: "form-control", rows: 5, placeholder: "Tell us about your project or how we can help...", required: true %>
    </div>

    <div class="d-grid">
      <%= f.submit "Send Message", class: "btn btn-primary btn-lg" %>
    </div>
  <% end %>
</div>

