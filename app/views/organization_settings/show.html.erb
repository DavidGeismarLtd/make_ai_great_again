<% content_for :page_title, "Organization Settings" %>

<% content_for :breadcrumbs do %>
  <%= render "shared/breadcrumbs", breadcrumbs: [
    { name: current_organization.name, url: main_app.org_prompt_tracker_path(current_organization.slug) },
    { name: "Settings", url: nil }
  ] %>
<% end %>

<div class="container-fluid py-4">
  <div class="row mb-4">
    <div class="col-12">
      <h1 class="h2 mb-2">Organization Settings</h1>
      <p class="text-muted">
        Configure AgentsOnRails settings for <%= current_organization.name %>
      </p>
    </div>
  </div>

  <div class="row g-4">
    <!-- Team Invitations Card -->
    <div class="col-md-6">
      <div class="card h-100">
        <div class="card-body">
          <div class="d-flex align-items-center mb-3">
            <div class="flex-shrink-0">
              <div class="bg-info bg-opacity-10 rounded-3 p-3">
                <i class="bi bi-people text-info fs-3"></i>
              </div>
            </div>
            <div class="flex-grow-1 ms-3">
              <h5 class="card-title mb-1">Team Invitations</h5>
              <p class="text-muted small mb-0">
                Invite team members to join your organization
              </p>
            </div>
          </div>

          <div class="mb-3">
            <h6 class="small text-uppercase text-muted mb-2">Quick Stats:</h6>
            <ul class="list-unstyled mb-0">
              <li class="mb-2">
                <div class="d-flex align-items-center">
                  <i class="bi bi-people-fill text-primary me-2"></i>
                  <div>
                    <strong><%= current_organization.users.count %></strong>
                    <small class="text-muted">Team Members</small>
                  </div>
                </div>
              </li>
              <li class="mb-2">
                <div class="d-flex align-items-center">
                  <i class="bi bi-clock-history text-warning me-2"></i>
                  <div>
                    <strong><%= current_organization.organization_invitations.pending.count %></strong>
                    <small class="text-muted">Pending Invitations</small>
                  </div>
                </div>
              </li>
            </ul>
          </div>

          <%= link_to org_organization_invitations_path(current_organization.slug),
                      class: "btn btn-outline-info w-100" do %>
            <i class="bi bi-envelope-plus me-2"></i>
            Manage Invitations
          <% end %>
        </div>
      </div>
    </div>

    <!-- Contexts Card -->
    <div class="col-md-6">
      <div class="card h-100">
        <div class="card-body">
          <div class="d-flex align-items-center mb-3">
            <div class="flex-shrink-0">
              <div class="bg-primary bg-opacity-10 rounded-3 p-3">
                <i class="bi bi-sliders text-primary fs-3"></i>
              </div>
            </div>
            <div class="flex-grow-1 ms-3">
              <h5 class="card-title mb-1">Context Settings</h5>
              <p class="text-muted small mb-0">
                Configure default providers and models for each context
              </p>
            </div>
          </div>

          <div class="mb-3">
            <h6 class="small text-uppercase text-muted mb-2">Available Contexts:</h6>
            <ul class="list-unstyled mb-0">
              <% @organization_configuration.contexts_config.each do |context_name, context_config| %>
                <li class="mb-2">
                  <div class="d-flex align-items-center">
                    <i class="bi bi-check-circle text-success me-2"></i>
                    <div>
                      <strong><%= context_name.to_s.titleize %></strong>
                      <br>
                      <small class="text-muted">
                        <%= context_config["default_provider"]&.titleize %> -
                        <%= context_config["default_model"] %>
                      </small>
                    </div>
                  </div>
                </li>
              <% end %>
            </ul>
          </div>

          <%= link_to contexts_org_organization_settings_path(current_organization.slug),
                      class: "btn btn-outline-primary w-100" do %>
            <i class="bi bi-pencil me-2"></i>
            Edit Context Settings
          <% end %>
        </div>
      </div>
    </div>

    <!-- Features Card -->
    <div class="col-md-6">
      <div class="card h-100">
        <div class="card-body">
          <div class="d-flex align-items-center mb-3">
            <div class="flex-shrink-0">
              <div class="bg-success bg-opacity-10 rounded-3 p-3">
                <i class="bi bi-toggles text-success fs-3"></i>
              </div>
            </div>
            <div class="flex-grow-1 ms-3">
              <h5 class="card-title mb-1">Feature Flags</h5>
              <p class="text-muted small mb-0">
                Enable or disable optional features
              </p>
            </div>
          </div>

          <div class="mb-3">
            <h6 class="small text-uppercase text-muted mb-2">Current Features:</h6>
            <ul class="list-unstyled mb-0">
              <% @organization_configuration.features_config.each do |feature_name, enabled| %>
                <li class="mb-2">
                  <div class="d-flex align-items-center">
                    <% if enabled %>
                      <i class="bi bi-toggle-on text-success me-2 fs-5"></i>
                    <% else %>
                      <i class="bi bi-toggle-off text-muted me-2 fs-5"></i>
                    <% end %>
                    <div>
                      <strong><%= feature_name.to_s.titleize %></strong>
                      <br>
                      <small class="text-muted">
                        <%= enabled ? "Enabled" : "Disabled" %>
                      </small>
                    </div>
                  </div>
                </li>
              <% end %>
            </ul>
          </div>

          <%= link_to features_org_organization_settings_path(current_organization.slug),
                      class: "btn btn-outline-success w-100" do %>
            <i class="bi bi-pencil me-2"></i>
            Edit Feature Flags
          <% end %>
        </div>
      </div>
    </div>
    <!-- Function Providers Card -->
    <div class="col-md-6">
      <div class="card h-100">
        <div class="card-body">
          <div class="d-flex align-items-center mb-3">
            <div class="flex-shrink-0">
              <div class="bg-warning bg-opacity-10 rounded-3 p-3">
                <i class="bi bi-cloud-arrow-up text-warning fs-3"></i>
              </div>
            </div>
            <div class="flex-grow-1 ms-3">
              <h5 class="card-title mb-1">Function Providers</h5>
              <p class="text-muted small mb-0">
                Configure cloud providers for executing agent functions
              </p>
            </div>
          </div>

          <div class="mb-3">
            <h6 class="small text-uppercase text-muted mb-2">Configured Providers:</h6>
            <ul class="list-unstyled mb-0">
              <% aws_config = @organization_configuration.function_providers_config["aws_lambda"] %>
              <li class="mb-2">
                <div class="d-flex align-items-center">
                  <% if aws_config.present? && aws_config["access_key_id"].present? %>
                    <i class="bi bi-check-circle text-success me-2"></i>
                  <% else %>
                    <i class="bi bi-dash-circle text-muted me-2"></i>
                  <% end %>
                  <div>
                    <strong>AWS Lambda</strong>
                    <br>
                    <small class="text-muted">
                      <%= aws_config.present? && aws_config["region"].present? ? "Region: #{aws_config["region"]}" : "Not configured" %>
                    </small>
                  </div>
                </div>
              </li>
            </ul>
          </div>

          <%= link_to function_providers_org_organization_settings_path(current_organization.slug),
                      class: "btn btn-outline-warning w-100" do %>
            <i class="bi bi-pencil me-2"></i>
            Edit Function Providers
          <% end %>
        </div>
      </div>
    </div>

    <!-- Assistant Chatbot Card -->
    <div class="col-md-6">
      <div class="card h-100">
        <div class="card-body">
          <div class="d-flex align-items-center mb-3">
            <div class="flex-shrink-0">
              <div class="bg-purple bg-opacity-10 rounded-3 p-3" style="background-color: rgba(111, 66, 193, 0.1) !important;">
                <i class="bi bi-chat-dots text-purple fs-3" style="color: #6f42c1 !important;"></i>
              </div>
            </div>
            <div class="flex-grow-1 ms-3">
              <h5 class="card-title mb-1">Assistant Chatbot</h5>
              <p class="text-muted small mb-0">
                Configure the built-in AI assistant chatbot
              </p>
            </div>
          </div>

          <div class="mb-3">
            <h6 class="small text-uppercase text-muted mb-2">Status:</h6>
            <ul class="list-unstyled mb-0">
              <% chatbot_config = @organization_configuration.assistant_chatbot_config %>
              <li class="mb-2">
                <div class="d-flex align-items-center">
                  <% if chatbot_config["enabled"].to_s == "true" %>
                    <i class="bi bi-toggle-on text-success me-2 fs-5"></i>
                  <% else %>
                    <i class="bi bi-toggle-off text-muted me-2 fs-5"></i>
                  <% end %>
                  <div>
                    <strong><%= chatbot_config["enabled"].to_s == "true" ? "Enabled" : "Disabled" %></strong>
                    <br>
                    <small class="text-muted">
                      <%= chatbot_config.dig("model", "provider")&.titleize %> - <%= chatbot_config.dig("model", "model") %>
                    </small>
                  </div>
                </div>
              </li>
            </ul>
          </div>

          <%= link_to assistant_chatbot_org_organization_settings_path(current_organization.slug),
                      class: "btn btn-outline-secondary w-100" do %>
            <i class="bi bi-pencil me-2"></i>
            Edit Chatbot Settings
          <% end %>
        </div>
      </div>
    </div>
    <!-- MCP Servers Card -->
    <div class="col-md-6">
      <div class="card h-100">
        <div class="card-body">
          <div class="d-flex align-items-center mb-3">
            <div class="flex-shrink-0">
              <div class="bg-teal bg-opacity-10 rounded-3 p-3" style="background-color: rgba(32, 201, 151, 0.1) !important;">
                <i class="bi bi-plug text-teal fs-3" style="color: #20c997 !important;"></i>
              </div>
            </div>
            <div class="flex-grow-1 ms-3">
              <h5 class="card-title mb-1">MCP Servers</h5>
              <p class="text-muted small mb-0">
                External tools and resources for AI agents
              </p>
            </div>
          </div>

          <div class="mb-3">
            <h6 class="small text-uppercase text-muted mb-2">Available Servers:</h6>
            <ul class="list-unstyled mb-0">
              <% mcp_config = @organization_configuration.mcp_servers_config %>
              <% { "filesystem" => "Filesystem", "slack" => "Slack" }.each do |key, label| %>
                <li class="mb-2">
                  <div class="d-flex align-items-center">
                    <% if mcp_config.dig(key, "enabled").to_s == "true" %>
                      <i class="bi bi-toggle-on text-success me-2 fs-5"></i>
                    <% else %>
                      <i class="bi bi-toggle-off text-muted me-2 fs-5"></i>
                    <% end %>
                    <div>
                      <strong><%= label %></strong>
                      <br>
                      <small class="text-muted">
                        <%= mcp_config.dig(key, "enabled").to_s == "true" ? "Enabled" : "Disabled" %>
                      </small>
                    </div>
                  </div>
                </li>
              <% end %>
            </ul>
          </div>

          <%= link_to mcp_servers_org_organization_settings_path(current_organization.slug),
                      class: "btn btn-outline-secondary w-100" do %>
            <i class="bi bi-pencil me-2"></i>
            Edit MCP Servers
          <% end %>
        </div>
      </div>
    </div>
  </div>

  <!-- Info Alert -->
  <div class="row mt-4">
    <div class="col-12">
      <div class="alert alert-info">
        <h5 class="alert-heading">
          <i class="bi bi-info-circle me-2"></i>
          About Organization Settings
        </h5>
        <p class="mb-2">
          <strong>Contexts:</strong> Define default LLM providers and models for different use cases (playground, LLM judge, dataset generation, etc.)
        </p>
        <p class="mb-2">
          <strong>Features:</strong> Enable or disable optional functionality like OpenAI Assistant sync, functions, monitoring, etc.
        </p>
        <p class="mb-2">
          <strong>Function Providers:</strong> Configure cloud providers (AWS Lambda) for executing code-based agent functions.
        </p>
        <p class="mb-2">
          <strong>Assistant Chatbot:</strong> Enable and configure the built-in AI assistant that helps with prompt creation, testing, and navigation.
        </p>
        <p class="mb-0">
          <strong>MCP Servers:</strong> Enable external tool servers (Filesystem, Slack) that extend AI agent capabilities via the Model Context Protocol.
        </p>
      </div>
    </div>
  </div>
</div>
