<% content_for :page_title, "Edit Context Settings" %>

<% content_for :breadcrumbs do %>
  <%= render "shared/breadcrumbs", breadcrumbs: [
    { name: current_organization.name, url: main_app.org_prompt_tracker_path(current_organization.slug) },
    { name: "Settings", url: main_app.org_organization_settings_path(current_organization.slug) },
    { name: "Contexts", url: nil }
  ] %>
<% end %>

<div class="container-fluid py-4">
  <div class="row mb-4">
    <div class="col-12">
      <h1 class="h2 mb-2">Context Settings</h1>
      <p class="text-muted">
        Configure default providers and models for each context in <%= current_organization.name %>
      </p>
    </div>
  </div>

  <%= form_with url: update_contexts_org_organization_settings_path(current_organization.slug),
                method: :patch,
                local: true do |f| %>

    <div class="row">
      <div class="col-lg-8">
        <div class="card">
          <div class="card-body">
            <% OrganizationConfiguration::DEFAULT_CONTEXTS.each do |context_name, default_config| %>
              <% current_config = @organization_configuration.contexts_config[context_name.to_s] || default_config.stringify_keys %>

              <div class="mb-4 pb-4 border-bottom"
                   data-controller="context-form"
                   data-context-form-provider-apis-value="<%= provider_apis_json %>"
                   data-context-form-provider-models-value="<%= provider_models_json %>">
                <h5 class="mb-3">
                  <i class="bi bi-circle-fill text-primary me-2" style="font-size: 0.5rem;"></i>
                  <%= context_name.to_s.titleize %>
                </h5>
                <p class="text-muted small mb-3">
                  <%= default_config[:description] %>
                </p>

                <div class="row g-3">
                  <div class="col-md-6">
                    <%= label_tag "contexts_config[#{context_name}][default_provider]", "Default Provider", class: "form-label" %>
                    <%= select_tag "contexts_config[#{context_name}][default_provider]",
                                   options_for_select(
                                     @configured_providers.map { |p| [p.titleize, p] },
                                     current_config["default_provider"]
                                   ),
                                   class: "form-select",
                                   data: {
                                     context_form_target: "providerSelect",
                                     action: "change->context-form#providerChanged"
                                   } %>
                    <% if @configured_providers.empty? %>
                      <div class="form-text text-warning">
                        <i class="bi bi-exclamation-triangle me-1"></i>
                        No API keys configured. <%= link_to "Add API keys", org_api_configurations_path(current_organization.slug), class: "text-decoration-none" %>
                      </div>
                    <% end %>
                  </div>

                  <div class="col-md-6">
                    <%= label_tag "contexts_config[#{context_name}][default_api]", "Default API", class: "form-label" %>
                    <%= select_tag "contexts_config[#{context_name}][default_api]",
                                   options_for_select(
                                     apis_for_provider(current_config["default_provider"]).map { |api| [api[:label], api[:value]] },
                                     current_config["default_api"]
                                   ),
                                   class: "form-select",
                                   data: { context_form_target: "apiSelect" } %>
                  </div>

                  <div class="col-md-6">
                    <%= label_tag "contexts_config[#{context_name}][default_model]", "Default Model", class: "form-label" %>
                    <%= select_tag "contexts_config[#{context_name}][default_model]",
                                   options_for_select(
                                     models_for_provider(current_config["default_provider"]).map { |model| [model[:label], model[:value]] },
                                     current_config["default_model"]
                                   ),
                                   class: "form-select",
                                   data: { context_form_target: "modelSelect" } %>
                  </div>

                  <% if current_config["default_temperature"] %>
                    <div class="col-md-6">
                      <%= label_tag "contexts_config[#{context_name}][default_temperature]", "Default Temperature", class: "form-label" %>
                      <%= number_field_tag "contexts_config[#{context_name}][default_temperature]",
                                           current_config["default_temperature"],
                                           class: "form-control",
                                           step: 0.1,
                                           min: 0,
                                           max: 2 %>
                    </div>
                  <% end %>

                  <div class="col-12">
                    <%= text_area_tag "contexts_config[#{context_name}][description]",
                                      current_config["description"],
                                      class: "form-control",
                                      rows: 2,
                                      placeholder: "Description" %>
                  </div>
                </div>
              </div>
            <% end %>

            <div class="d-flex gap-2">
              <%= f.submit "Save Context Settings", class: "btn btn-primary" %>
              <%= link_to "Cancel", org_organization_settings_path(current_organization.slug), class: "btn btn-outline-secondary" %>
            </div>
          </div>
        </div>
      </div>

      <div class="col-lg-4">
        <div class="card bg-light">
          <div class="card-body">
            <h6 class="card-title">
              <i class="bi bi-info-circle me-2"></i>
              About Contexts
            </h6>
            <p class="small mb-3">
              Contexts define default settings for different use cases in PromptTracker:
            </p>
            <ul class="small mb-0">
              <li class="mb-2"><strong>Playground:</strong> Testing prompt versions interactively</li>
              <li class="mb-2"><strong>LLM Judge:</strong> Automated evaluation of responses</li>
              <li class="mb-2"><strong>Dataset Generation:</strong> Creating test data</li>
              <li class="mb-2"><strong>Prompt Generation:</strong> AI-assisted prompt creation</li>
              <li class="mb-2"><strong>Test Generation:</strong> Generating test cases</li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  <% end %>
</div>
