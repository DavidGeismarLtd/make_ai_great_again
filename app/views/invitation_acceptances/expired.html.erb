<% content_for :page_title, "Invitation Expired" %>

<div class="container py-5">
  <div class="row justify-content-center">
    <div class="col-lg-6">
      <div class="card shadow">
        <div class="card-body p-5 text-center">
          <div class="mb-4">
            <i class="bi bi-clock-history text-warning" style="font-size: 4rem;"></i>
          </div>
          
          <h2 class="mb-3">Invitation Expired</h2>
          
          <p class="lead mb-4">
            This invitation to join <strong><%= @invitation.organization.name %></strong> has expired.
          </p>

          <div class="alert alert-warning">
            <p class="mb-0">
              This invitation expired on <%= @invitation.expires_at.strftime("%B %d, %Y at %I:%M %p") %>.
            </p>
          </div>

          <p class="text-muted">
            Please contact <strong><%= @invitation.invited_by.full_name %></strong> 
            (<%= @invitation.invited_by.email %>) to request a new invitation.
          </p>

          <div class="mt-4">
            <%= link_to "Back to Home", root_path, class: "btn btn-outline-primary" %>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

