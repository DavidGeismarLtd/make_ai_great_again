<div class="container mt-5">
  <div class="row justify-content-center">
    <div class="col-md-6">
      <div class="card shadow-sm">
        <div class="card-body p-5">
          <div class="text-center mb-4">
            <h2 class="h3 mb-3">Complete Your Account</h2>
            <p class="text-muted">
              You've been invited to join <strong><%= @invitation.organization.name %></strong>
            </p>
            <p class="text-muted small">
              Invited by <%= @invitation.invited_by.full_name %> as a <strong><%= @invitation.role.titleize %></strong>
            </p>
          </div>

          <%= form_with model: @user, url: create_account_invitation_path(@invitation.token), method: :post, local: true do |f| %>
            <%= render "devise/shared/error_messages", resource: @user %>

            <div class="mb-3">
              <label class="form-label">Email</label>
              <input type="email" class="form-control" value="<%= @invitation.email %>" disabled>
              <small class="form-text text-muted">This email is set by the invitation</small>
            </div>

            <div class="mb-3">
              <%= f.label :first_name, class: "form-label" %>
              <%= f.text_field :first_name, class: "form-control", placeholder: "Enter your first name", autofocus: true, required: true %>
            </div>

            <div class="mb-3">
              <%= f.label :last_name, class: "form-label" %>
              <%= f.text_field :last_name, class: "form-control", placeholder: "Enter your last name", required: true %>
            </div>

            <div class="mb-3">
              <%= f.label :password, class: "form-label" %>
              <%= f.password_field :password, class: "form-control", placeholder: "Choose a password (minimum 6 characters)", autocomplete: "new-password", required: true %>
              <% if @minimum_password_length %>
                <small class="form-text text-muted">
                  <%= @minimum_password_length %> characters minimum
                </small>
              <% end %>
            </div>

            <div class="mb-4">
              <%= f.label :password_confirmation, class: "form-label" %>
              <%= f.password_field :password_confirmation, class: "form-control", placeholder: "Confirm your password", autocomplete: "new-password", required: true %>
            </div>

            <div class="d-grid">
              <%= f.submit "Create Account & Join Organization", class: "btn btn-primary btn-lg" %>
            </div>
          <% end %>

          <div class="text-center mt-4">
            <p class="text-muted small">
              Already have an account? <%= link_to "Sign in", new_user_session_path %>
            </p>
          </div>
        </div>
      </div>

      <div class="text-center mt-3">
        <small class="text-muted">
          By creating an account, you agree to our
          <%= link_to "Terms of Service", terms_path %> and
          <%= link_to "Privacy Policy", privacy_path %>
        </small>
      </div>
    </div>
  </div>
</div>

