<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <style>
    body {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
      line-height: 1.6;
      color: #333;
      max-width: 600px;
      margin: 0 auto;
      padding: 20px;
    }
    .header {
      text-align: center;
      padding: 20px 0;
      border-bottom: 2px solid #f0f0f0;
    }
    .header h1 {
      margin: 0;
      color: #2563eb;
      font-size: 24px;
    }
    .content {
      padding: 30px 0;
    }
    .greeting {
      font-size: 18px;
      margin-bottom: 20px;
    }
    .footer {
      margin-top: 40px;
      padding-top: 20px;
      border-top: 1px solid #e5e7eb;
      font-size: 14px;
      color: #6b7280;
      text-align: center;
    }
    .info {
      background-color: #dbeafe;
      border-left: 4px solid #2563eb;
      padding: 12px 16px;
      margin: 20px 0;
      font-size: 14px;
    }
    .warning {
      background-color: #fef3c7;
      border-left: 4px solid #f59e0b;
      padding: 12px 16px;
      margin: 20px 0;
      font-size: 14px;
    }
  </style>
</head>
<body>
  <div class="header">
    <h1>PromptTracker</h1>
  </div>

  <div class="content">
    <p class="greeting">Hi <%= @resource.first_name || 'there' %>! 👋</p>

    <% if @resource.try(:unconfirmed_email?) %>
      <p>This is a security notification to let you know that your email address is being changed.</p>

      <div class="info">
        <strong>📧 New Email Address:</strong> <%= @resource.unconfirmed_email %>
      </div>

      <p>You'll need to confirm your new email address before the change takes effect. We've sent a confirmation link to your new email.</p>
    <% else %>
      <p>This is a security notification to let you know that your email address has been successfully changed.</p>

      <div class="info">
        <strong>📧 New Email Address:</strong> <%= @resource.email %>
      </div>

      <p>This change is now active. You'll use this new email address to sign in to PromptTracker.</p>
    <% end %>

    <div class="warning">
      <strong>⚠️ Didn't make this change?</strong> If you didn't request this email change, please contact our support team immediately to secure your account.
    </div>

    <p>Best regards,<br>
    The PromptTracker Team</p>
  </div>

  <div class="footer">
    <p>This notification was sent to <%= @email %></p>
    <p>PromptTracker - AI Prompt Management & Testing Platform</p>
  </div>
</body>
</html>
