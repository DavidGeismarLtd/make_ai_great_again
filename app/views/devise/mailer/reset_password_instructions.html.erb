<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <style>
    body {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
      line-height: 1.6;
      color: #333;
      max-width: 600px;
      margin: 0 auto;
      padding: 20px;
    }
    .header {
      text-align: center;
      padding: 20px 0;
      border-bottom: 2px solid #f0f0f0;
    }
    .header h1 {
      margin: 0;
      color: #2563eb;
      font-size: 24px;
    }
    .content {
      padding: 30px 0;
    }
    .greeting {
      font-size: 18px;
      margin-bottom: 20px;
    }
    .button {
      display: inline-block;
      padding: 14px 28px;
      background-color: #2563eb;
      color: white !important;
      text-decoration: none;
      border-radius: 6px;
      font-weight: 600;
      margin: 20px 0;
    }
    .button:hover {
      background-color: #1d4ed8;
    }
    .footer {
      margin-top: 40px;
      padding-top: 20px;
      border-top: 1px solid #e5e7eb;
      font-size: 14px;
      color: #6b7280;
      text-align: center;
    }
    .warning {
      background-color: #fef3c7;
      border-left: 4px solid #f59e0b;
      padding: 12px 16px;
      margin: 20px 0;
      font-size: 14px;
    }
  </style>
</head>
<body>
  <div class="header">
    <h1>PromptTracker</h1>
  </div>

  <div class="content">
    <p class="greeting">Hi <%= @resource.first_name || 'there' %>! 👋</p>

    <p>We received a request to reset your password for your PromptTracker account.</p>

    <p>Click the button below to choose a new password:</p>

    <div style="text-align: center;">
      <%= link_to 'Reset My Password', edit_password_url(@resource, reset_password_token: @token), class: 'button' %>
    </div>

    <div class="warning">
      <strong>⚠️ Security Notice:</strong> If you didn't request a password reset, please ignore this email. Your password will remain unchanged.
    </div>

    <p><strong>Important:</strong></p>
    <ul>
      <li>This link will expire in 6 hours</li>
      <li>Your password won't change until you click the link and set a new one</li>
      <li>If you continue to receive these emails, please contact our support team</li>
    </ul>

    <p>Best regards,<br>
    The PromptTracker Team</p>
  </div>

  <div class="footer">
    <p>This email was sent to <%= @resource.email %></p>
    <p>PromptTracker - AI Prompt Management & Testing Platform</p>
  </div>
</body>
</html>
