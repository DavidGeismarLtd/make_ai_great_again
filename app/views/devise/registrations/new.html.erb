<div class="container">
  <div class="row justify-content-center min-vh-100 align-items-center">
    <div class="col-md-6 col-lg-5">
      <div class="text-center mb-4">
        <h1 class="h3 mb-2">Create your account</h1>
        <p class="text-muted">Get started with your free account</p>
      </div>

      <div class="card shadow-sm">
        <div class="card-body p-4">
          <%= form_for(resource, as: resource_name, url: registration_path(resource_name)) do |f| %>
            <%= render "devise/shared/error_messages", resource: resource %>

            <div class="row g-3 mb-3">
              <div class="col-md-6">
                <%= f.label :first_name, class: "form-label" %>
                <%= f.text_field :first_name,
                                 autofocus: true,
                                 class: "form-control form-control-lg",
                                 placeholder: "First name" %>
              </div>

              <div class="col-md-6">
                <%= f.label :last_name, class: "form-label" %>
                <%= f.text_field :last_name,
                                 class: "form-control form-control-lg",
                                 placeholder: "Last name" %>
              </div>
            </div>

            <div class="mb-3">
              <%= f.label :email, class: "form-label" %>
              <%= f.email_field :email,
                                autocomplete: "email",
                                class: "form-control form-control-lg",
                                placeholder: "you@example.com" %>
            </div>

            <div class="mb-3">
              <%= f.label :password, class: "form-label" %>
              <%= f.password_field :password,
                                   autocomplete: "new-password",
                                   class: "form-control form-control-lg",
                                   placeholder: "Create a password" %>
              <% if @minimum_password_length %>
                <div class="form-text">
                  Minimum <%= @minimum_password_length %> characters
                </div>
              <% end %>
            </div>

            <div class="mb-4">
              <%= f.label :password_confirmation, "Confirm Password", class: "form-label" %>
              <%= f.password_field :password_confirmation,
                                   autocomplete: "new-password",
                                   class: "form-control form-control-lg",
                                   placeholder: "Confirm your password" %>
            </div>

            <div class="d-grid">
              <%= f.submit "Create Account", class: "btn btn-primary btn-lg" %>
            </div>
          <% end %>
        </div>
      </div>

      <div class="text-center mt-3">
        <p class="text-muted mb-0">
          Already have an account?
          <%= link_to "Sign in", new_session_path(resource_name), class: "text-decoration-none fw-semibold" %>
        </p>
      </div>
    </div>
  </div>
</div>
