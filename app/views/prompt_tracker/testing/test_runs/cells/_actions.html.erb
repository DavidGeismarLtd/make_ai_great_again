<%# Override of PromptTracker gem's view to include org_slug in URL generation %>
<%# Original: PromptTracker (9ae3f09de9c4) app/views/prompt_tracker/testing/test_runs/cells/_actions.html.erb %>

<td data-column="actions">
  <%= button_to rerun_testing_run_path(run, org_slug: current_organization.slug),
                method: :post,
                class: "btn btn-sm btn-outline-secondary me-1",
                title: "Re-run test with same configuration",
                form: { style: "display: inline;" } do %>
    <i class="bi bi-arrow-clockwise"></i>
  <% end %>

  <button type="button"
          class="btn btn-sm btn-primary"
          data-bs-toggle="modal"
          data-bs-target="#human-evaluation-modal-<%= run.id %>"
          title="Add Human Evaluation">
    <i class="bi bi-person-check"></i>
  </button>
   <%= render "prompt_tracker/shared/human_evaluation_modal_form",
                   record: run,
                   form_url: testing_run_human_evaluations_path(run, org_slug: current_organization.slug),
                   context: 'testing' %>
</td>
