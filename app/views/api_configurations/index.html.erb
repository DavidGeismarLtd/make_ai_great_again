<% content_for :page_title, "API Keys" %>

<% content_for :breadcrumbs do %>
  <%= render "shared/breadcrumbs", breadcrumbs: [
    { name: current_organization.name, url: main_app.org_prompt_tracker_path(current_organization.slug) },
    { name: "API Keys", url: nil }
  ] %>
<% end %>

<div class="container-fluid py-4">
  <div class="row mb-4">
    <div class="col-12">
      <div class="d-flex justify-content-between align-items-center">
        <div>
          <h1 class="h2 mb-2">API Keys</h1>
          <p class="text-muted">
            Manage your LLM provider API keys. These keys are encrypted and used to make calls to OpenAI, Anthropic, Google, and other providers.
          </p>
        </div>
        <%= link_to "Add API Key", new_org_api_configuration_path(current_organization.slug), class: "btn btn-primary" %>
      </div>
    </div>
  </div>

  <% if @api_configurations.any? %>
    <div class="row">
      <div class="col-12">
        <div class="card">
          <div class="card-body">
            <div class="table-responsive">
              <table class="table table-hover align-middle">
                <thead>
                  <tr>
                    <th>Provider</th>
                    <th>Key Name</th>
                    <th>API Key</th>
                    <th>Status</th>
                    <th>Last Validated</th>
                    <th class="text-end">Actions</th>
                  </tr>
                </thead>
                <tbody>
                  <% @api_configurations.each do |api_config| %>
                    <tr>
                      <td>
                        <span class="badge bg-primary">
                          <%= api_config.provider.titleize %>
                        </span>
                      </td>
                      <td><%= api_config.key_name %></td>
                      <td>
                        <code class="text-muted"><%= api_config.masked_key %></code>
                      </td>
                      <td>
                        <% if api_config.is_active? %>
                          <span class="badge bg-success">Active</span>
                        <% else %>
                          <span class="badge bg-secondary">Inactive</span>
                        <% end %>
                      </td>
                      <td>
                        <% if api_config.last_validated_at %>
                          <span class="text-muted" title="<%= api_config.last_validated_at.strftime('%Y-%m-%d %H:%M:%S') %>">
                            <%= time_ago_in_words(api_config.last_validated_at) %> ago
                          </span>
                        <% else %>
                          <span class="text-muted">Never</span>
                        <% end %>
                      </td>
                      <td class="text-end">
                        <div class="btn-group btn-group-sm" role="group">
                          <%= button_to "Test", 
                                        test_connection_org_api_configuration_path(current_organization.slug, api_config), 
                                        method: :post,
                                        class: "btn btn-outline-secondary",
                                        title: "Test API key connection" %>
                          <%= link_to "Edit", 
                                      edit_org_api_configuration_path(current_organization.slug, api_config), 
                                      class: "btn btn-outline-primary" %>
                          <%= button_to "Delete", 
                                        org_api_configuration_path(current_organization.slug, api_config), 
                                        method: :delete,
                                        class: "btn btn-outline-danger",
                                        form: { data: { turbo_confirm: "Are you sure you want to delete this API key?" } } %>
                        </div>
                      </td>
                    </tr>
                  <% end %>
                </tbody>
              </table>
            </div>
          </div>
        </div>
      </div>
    </div>
  <% else %>
    <div class="row">
      <div class="col-12">
        <div class="card">
          <div class="card-body text-center py-5">
            <i class="bi bi-key display-1 text-muted mb-3"></i>
            <h3 class="mb-3">No API Keys Configured</h3>
            <p class="text-muted mb-4">
              Add your first API key to start using PromptTracker with LLM providers like OpenAI, Anthropic, or Google.
            </p>
            <%= link_to "Add Your First API Key", new_org_api_configuration_path(current_organization.slug), class: "btn btn-primary btn-lg" %>
          </div>
        </div>
      </div>
    </div>
  <% end %>

  <div class="row mt-4">
    <div class="col-12">
      <div class="alert alert-info">
        <h5 class="alert-heading">
          <i class="bi bi-info-circle me-2"></i>
          About API Keys
        </h5>
        <p class="mb-2">
          <strong>Security:</strong> All API keys are encrypted at rest using Rails' built-in encryption. They are only decrypted when making LLM API calls.
        </p>
        <p class="mb-2">
          <strong>Supported Providers:</strong> OpenAI, Anthropic (Claude), Google (Gemini), Azure OpenAI
        </p>
        <p class="mb-0">
          <strong>Multiple Keys:</strong> You can add multiple keys for the same provider (e.g., production and development keys).
        </p>
      </div>
    </div>
  </div>
</div>

