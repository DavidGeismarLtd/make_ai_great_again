<% content_for :page_title, "Team Invitations" %>

<% content_for :breadcrumbs do %>
  <%= render "shared/breadcrumbs", breadcrumbs: [
    { name: current_organization.name, url: main_app.org_prompt_tracker_path(current_organization.slug) },
    { name: "Settings", url: main_app.org_organization_settings_path(current_organization.slug) },
    { name: "Invitations", url: nil }
  ] %>
<% end %>

<div class="container-fluid py-4">
  <div class="row mb-4">
    <div class="col-md-8">
      <h1 class="h2 mb-2">Team Invitations</h1>
      <p class="text-muted">
        Invite new members to join <%= current_organization.name %>
      </p>
    </div>
    <div class="col-md-4 text-end">
      <%= link_to new_org_organization_invitation_path(current_organization.slug), 
                  class: "btn btn-primary" do %>
        <i class="bi bi-envelope-plus me-2"></i>
        Send Invitation
      <% end %>
    </div>
  </div>

  <!-- Pending Invitations -->
  <div class="row mb-4">
    <div class="col-12">
      <div class="card">
        <div class="card-header">
          <h5 class="mb-0">
            <i class="bi bi-clock-history me-2"></i>
            Pending Invitations
            <span class="badge bg-primary ms-2"><%= @pending_invitations.count %></span>
          </h5>
        </div>
        <div class="card-body">
          <% if @pending_invitations.any? %>
            <div class="table-responsive">
              <table class="table table-hover">
                <thead>
                  <tr>
                    <th>Email</th>
                    <th>Role</th>
                    <th>Invited By</th>
                    <th>Sent</th>
                    <th>Expires</th>
                    <th>Actions</th>
                  </tr>
                </thead>
                <tbody>
                  <% @pending_invitations.each do |invitation| %>
                    <tr>
                      <td><%= invitation.email %></td>
                      <td><span class="badge bg-info"><%= invitation.role.titleize %></span></td>
                      <td><%= invitation.invited_by.full_name %></td>
                      <td><%= time_ago_in_words(invitation.created_at) %> ago</td>
                      <td><%= invitation.expires_at.strftime("%b %d, %Y") %></td>
                      <td>
                        <%= button_to resend_org_organization_invitation_path(current_organization.slug, invitation),
                                      method: :post,
                                      class: "btn btn-sm btn-outline-primary me-2",
                                      title: "Resend invitation" do %>
                          <i class="bi bi-arrow-repeat"></i>
                        <% end %>
                        <%= button_to org_organization_invitation_path(current_organization.slug, invitation),
                                      method: :delete,
                                      class: "btn btn-sm btn-outline-danger",
                                      title: "Cancel invitation",
                                      data: { confirm: "Are you sure you want to cancel this invitation?" } do %>
                          <i class="bi bi-trash"></i>
                        <% end %>
                      </td>
                    </tr>
                  <% end %>
                </tbody>
              </table>
            </div>
          <% else %>
            <p class="text-muted mb-0">No pending invitations</p>
          <% end %>
        </div>
      </div>
    </div>
  </div>

  <!-- Accepted Invitations -->
  <div class="row mb-4">
    <div class="col-12">
      <div class="card">
        <div class="card-header">
          <h5 class="mb-0">
            <i class="bi bi-check-circle me-2"></i>
            Recently Accepted
          </h5>
        </div>
        <div class="card-body">
          <% if @accepted_invitations.any? %>
            <div class="table-responsive">
              <table class="table table-sm">
                <thead>
                  <tr>
                    <th>Email</th>
                    <th>Role</th>
                    <th>Invited By</th>
                    <th>Accepted</th>
                  </tr>
                </thead>
                <tbody>
                  <% @accepted_invitations.each do |invitation| %>
                    <tr>
                      <td><%= invitation.email %></td>
                      <td><span class="badge bg-success"><%= invitation.role.titleize %></span></td>
                      <td><%= invitation.invited_by.full_name %></td>
                      <td><%= time_ago_in_words(invitation.accepted_at) %> ago</td>
                    </tr>
                  <% end %>
                </tbody>
              </table>
            </div>
          <% else %>
            <p class="text-muted mb-0">No accepted invitations yet</p>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</div>

