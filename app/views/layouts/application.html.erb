<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:page_title) || "AgentsOnRails - AI Agent Development Platform" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="AgentsOnRails">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%# Google Fonts - JetBrains Mono (AgentsOnRails font) %>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@300;400;500;600;700&display=swap" rel="stylesheet">

    <%# Bootstrap CSS and Icons from CDN (matching AgentsOnRails version) %>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-9ndCyUaIbzAi2FUVXJi0CjmCapSmO7SnpJef0486qhLnuZ2cdeRhO02iuK6FUUVM" crossorigin="anonymous">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">

    <%= yield :head %>

    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "landing", "data-turbo-track": "reload" %>

    <%# PromptTracker engine stylesheets %>
    <%= stylesheet_link_tag "prompt_tracker/application", media: "all" %>

    <%= javascript_importmap_tags %>
    <%= javascript_import_module_tag "application" %>
    <%= javascript_import_module_tag "prompt_tracker/application" %>

    <%# Theme Management Script (from PromptTracker) %>
    <script>
      // Get saved theme or default to light
      (function() {
        const savedTheme = localStorage.getItem('pt-theme') || 'light';
        document.documentElement.setAttribute('data-theme', savedTheme);
      })();

      // Chart.js instance registry for cleanup on Turbo navigation
      window.chartInstances = window.chartInstances || {};

      // Destroy all charts before Turbo cache
      document.addEventListener('turbo:before-cache', function() {
        Object.values(window.chartInstances).forEach(chart => {
          if (chart && typeof chart.destroy === 'function') {
            chart.destroy();
          }
        });
        window.chartInstances = {};
      });

      // Theme Toggle functionality
      document.addEventListener('DOMContentLoaded', function() {
        const themeToggle = document.getElementById('themeToggle');
        const themeIcon = document.getElementById('themeIcon');

        if (!themeToggle || !themeIcon) return;

        const currentTheme = document.documentElement.getAttribute('data-theme');

        // Set initial icon
        if (currentTheme === 'dark') {
          themeIcon.className = 'bi bi-moon-fill';
        } else {
          themeIcon.className = 'bi bi-sun-fill';
        }

        // Toggle theme
        themeToggle.addEventListener('click', function() {
          const theme = document.documentElement.getAttribute('data-theme');
          const newTheme = theme === 'dark' ? 'light' : 'dark';

          document.documentElement.setAttribute('data-theme', newTheme);
          localStorage.setItem('pt-theme', newTheme);

          // Update icon
          if (newTheme === 'dark') {
            themeIcon.className = 'bi bi-moon-fill';
          } else {
            themeIcon.className = 'bi bi-sun-fill';
          }
        });
      });
    </script>
  </head>

  <body>
    <%# Unified Navigation Bar %>
    <%= render "shared/navbar" %>

    <%# Breadcrumbs %>
    <%= render "shared/breadcrumbs" %>

    <%# Flash Messages %>
    <%= render "shared/flash_messages" %>

    <%# Main Content %>
    <div class="container-fluid main-content">
      <%= yield %>
    </div>
  </body>
</html>
