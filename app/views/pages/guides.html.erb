<div class="container py-5">
  <div class="row">
    <div class="col-12">
      <h1 class="mb-4">PromptTracker Guides</h1>
      <p class="lead text-muted mb-5">
        Learn how to manage, track, and optimize your LLM prompts with comprehensive testing and analytics
      </p>
    </div>
  </div>

  <div class="row g-4">
    <%# Getting Started Section %>
    <div class="col-12">
      <h2 class="h3 mb-4">Getting Started</h2>
    </div>

    <div class="col-md-6 col-lg-4">
      <div class="card h-100 border-primary">
        <div class="card-body">
          <div class="mb-3">
            <i class="bi bi-rocket-takeoff fs-1 text-primary"></i>
          </div>
          <h3 class="h5 card-title">Quick Start</h3>
          <p class="card-text">
            Get started with PromptTracker in 5 minutes. Create your account, set up your organization,
            and configure your first LLM provider.
          </p>
          <ul class="list-unstyled small">
            <li class="mb-2"><i class="bi bi-check-circle text-success me-2"></i>Create account & organization</li>
            <li class="mb-2"><i class="bi bi-check-circle text-success me-2"></i>Add API keys</li>
            <li class="mb-2"><i class="bi bi-check-circle text-success me-2"></i>Create your first prompt</li>
          </ul>
        </div>
      </div>
    </div>

    <div class="col-md-6 col-lg-4">
      <div class="card h-100">
        <div class="card-body">
          <div class="mb-3">
            <i class="bi bi-key fs-1 text-primary"></i>
          </div>
          <h3 class="h5 card-title">API Key Management</h3>
          <p class="card-text">
            Securely store and manage API keys for OpenAI, Anthropic, Google, and other LLM providers.
            All keys are encrypted at rest.
          </p>
          <ul class="list-unstyled small">
            <li class="mb-2"><i class="bi bi-check-circle text-success me-2"></i>Encrypted storage</li>
            <li class="mb-2"><i class="bi bi-check-circle text-success me-2"></i>Multiple providers</li>
            <li class="mb-2"><i class="bi bi-check-circle text-success me-2"></i>Connection testing</li>
          </ul>
        </div>
      </div>
    </div>

    <div class="col-md-6 col-lg-4">
      <div class="card h-100">
        <div class="card-body">
          <div class="mb-3">
            <i class="bi bi-people fs-1 text-primary"></i>
          </div>
          <h3 class="h5 card-title">Team Collaboration</h3>
          <p class="card-text">
            Invite team members to your organization. Manage roles and permissions for collaborative
            prompt development.
          </p>
          <ul class="list-unstyled small">
            <li class="mb-2"><i class="bi bi-check-circle text-success me-2"></i>Email invitations</li>
            <li class="mb-2"><i class="bi bi-check-circle text-success me-2"></i>Role-based access</li>
            <li class="mb-2"><i class="bi bi-check-circle text-success me-2"></i>Shared workspaces</li>
          </ul>
        </div>
      </div>
    </div>

    <%# Prompt Management Section %>
    <div class="col-12 mt-5">
      <h2 class="h3 mb-4">Prompt Management</h2>
    </div>

    <div class="col-md-6 col-lg-4">
      <div class="card h-100 border-primary">
        <div class="card-body">
          <div class="mb-3">
            <i class="bi bi-file-text fs-1 text-primary"></i>
          </div>
          <h3 class="h5 card-title">Creating Prompts</h3>
          <p class="card-text">
            Learn how to create and manage LLM prompts with variable substitution, templates,
            and version control.
          </p>
          <ul class="list-unstyled small">
            <li class="mb-2"><i class="bi bi-check-circle text-success me-2"></i>Prompt templates</li>
            <li class="mb-2"><i class="bi bi-check-circle text-success me-2"></i>Variable substitution</li>
            <li class="mb-2"><i class="bi bi-check-circle text-success me-2"></i>System messages</li>
            <li class="mb-2"><i class="bi bi-check-circle text-success me-2"></i>Model configuration</li>
          </ul>
        </div>
      </div>
    </div>

    <div class="col-md-6 col-lg-4">
      <div class="card h-100 border-primary">
        <div class="card-body">
          <div class="mb-3">
            <i class="bi bi-git fs-1 text-primary"></i>
          </div>
          <h3 class="h5 card-title">Version Control</h3>
          <p class="card-text">
            Every prompt change is automatically versioned. Track iterations, compare versions,
            and roll back to any previous state.
          </p>
          <ul class="list-unstyled small">
            <li class="mb-2"><i class="bi bi-check-circle text-success me-2"></i>Automatic versioning</li>
            <li class="mb-2"><i class="bi bi-check-circle text-success me-2"></i>Version comparison</li>
            <li class="mb-2"><i class="bi bi-check-circle text-success me-2"></i>One-click rollback</li>
            <li class="mb-2"><i class="bi bi-check-circle text-success me-2"></i>Change history</li>
          </ul>
        </div>
      </div>
    </div>

    <div class="col-md-6 col-lg-4">
      <div class="card h-100">
        <div class="card-body">
          <div class="mb-3">
            <i class="bi bi-play-circle fs-1 text-primary"></i>
          </div>
          <h3 class="h5 card-title">Playground Testing</h3>
          <p class="card-text">
            Test your prompts in real-time with the interactive playground. Try different variables
            and see results instantly.
          </p>
          <ul class="list-unstyled small">
            <li class="mb-2"><i class="bi bi-check-circle text-success me-2"></i>Live testing</li>
            <li class="mb-2"><i class="bi bi-check-circle text-success me-2"></i>Variable testing</li>
            <li class="mb-2"><i class="bi bi-check-circle text-success me-2"></i>Response preview</li>
          </ul>
        </div>
      </div>
    </div>

    <%# Testing & Evaluation Section %>
    <div class="col-12 mt-5">
      <h2 class="h3 mb-4">Testing & Evaluation</h2>
    </div>

    <div class="col-md-6 col-lg-4">
      <div class="card h-100 border-primary">
        <div class="card-body">
          <div class="mb-3">
            <i class="bi bi-check2-square fs-1 text-primary"></i>
          </div>
          <h3 class="h5 card-title">Automated Testing</h3>
          <p class="card-text">
            Create test suites with multiple test cases. Run automated tests against your prompts
            before deploying to production.
          </p>
          <ul class="list-unstyled small">
            <li class="mb-2"><i class="bi bi-check-circle text-success me-2"></i>Test suite creation</li>
            <li class="mb-2"><i class="bi bi-check-circle text-success me-2"></i>Multiple evaluators</li>
            <li class="mb-2"><i class="bi bi-check-circle text-success me-2"></i>Automated execution</li>
            <li class="mb-2"><i class="bi bi-check-circle text-success me-2"></i>Pass/fail reporting</li>
          </ul>
        </div>
      </div>
    </div>

    <div class="col-md-6 col-lg-4">
      <div class="card h-100 border-primary">
        <div class="card-body">
          <div class="mb-3">
            <i class="bi bi-clipboard-check fs-1 text-primary"></i>
          </div>
          <h3 class="h5 card-title">Response Evaluators</h3>
          <p class="card-text">
            Configure multiple evaluators to automatically assess LLM responses: length checks,
            pattern matching, LLM-as-judge, and more.
          </p>
          <ul class="list-unstyled small">
            <li class="mb-2"><i class="bi bi-check-circle text-success me-2"></i>Length evaluator</li>
            <li class="mb-2"><i class="bi bi-check-circle text-success me-2"></i>Pattern matching</li>
            <li class="mb-2"><i class="bi bi-check-circle text-success me-2"></i>LLM-as-judge</li>
            <li class="mb-2"><i class="bi bi-check-circle text-success me-2"></i>Custom evaluators</li>
          </ul>
        </div>
      </div>
    </div>

    <div class="col-md-6 col-lg-4">
      <div class="card h-100 border-primary">
        <div class="card-body">
          <div class="mb-3">
            <i class="bi bi-database fs-1 text-primary"></i>
          </div>
          <h3 class="h5 card-title">Test Datasets</h3>
          <p class="card-text">
            Build reusable datasets with test cases and expected outputs. Run your prompts against
            comprehensive test scenarios.
          </p>
          <ul class="list-unstyled small">
            <li class="mb-2"><i class="bi bi-check-circle text-success me-2"></i>Dataset management</li>
            <li class="mb-2"><i class="bi bi-check-circle text-success me-2"></i>Test case library</li>
            <li class="mb-2"><i class="bi bi-check-circle text-success me-2"></i>Expected outputs</li>
            <li class="mb-2"><i class="bi bi-check-circle text-success me-2"></i>Batch testing</li>
          </ul>
        </div>
      </div>
    </div>

    <%# Tracking & Analytics Section %>
    <div class="col-12 mt-5">
      <h2 class="h3 mb-4">Tracking & Analytics</h2>
    </div>

    <div class="col-md-6 col-lg-4">
      <div class="card h-100">
        <div class="card-body">
          <div class="mb-3">
            <i class="bi bi-graph-up fs-1 text-primary"></i>
          </div>
          <h3 class="h5 card-title">LLM Call Tracking</h3>
          <p class="card-text">
            Automatically log all LLM API calls with metadata, tokens, costs, and response times.
            Full request/response history.
          </p>
          <ul class="list-unstyled small">
            <li class="mb-2"><i class="bi bi-check-circle text-success me-2"></i>Automatic logging</li>
            <li class="mb-2"><i class="bi bi-check-circle text-success me-2"></i>Token tracking</li>
            <li class="mb-2"><i class="bi bi-check-circle text-success me-2"></i>Cost calculation</li>
            <li class="mb-2"><i class="bi bi-check-circle text-success me-2"></i>Latency metrics</li>
          </ul>
        </div>
      </div>
    </div>

    <div class="col-md-6 col-lg-4">
      <div class="card h-100">
        <div class="card-body">
          <div class="mb-3">
            <i class="bi bi-bar-chart fs-1 text-primary"></i>
          </div>
          <h3 class="h5 card-title">Analytics Dashboard</h3>
          <p class="card-text">
            Monitor prompt performance, response quality, and costs over time. Identify trends
            and optimization opportunities.
          </p>
          <ul class="list-unstyled small">
            <li class="mb-2"><i class="bi bi-check-circle text-success me-2"></i>Performance metrics</li>
            <li class="mb-2"><i class="bi bi-check-circle text-success me-2"></i>Quality scores</li>
            <li class="mb-2"><i class="bi bi-check-circle text-success me-2"></i>Cost analysis</li>
            <li class="mb-2"><i class="bi bi-check-circle text-success me-2"></i>Usage trends</li>
          </ul>
        </div>
      </div>
    </div>

    <div class="col-md-6 col-lg-4">
      <div class="card h-100">
        <div class="card-body">
          <div class="mb-3">
            <i class="bi bi-shuffle fs-1 text-primary"></i>
          </div>
          <h3 class="h5 card-title">A/B Testing & Experiments</h3>
          <p class="card-text">
            Run experiments comparing different prompt versions. Make data-driven decisions
            with statistical analysis.
          </p>
          <ul class="list-unstyled small">
            <li class="mb-2"><i class="bi bi-check-circle text-success me-2"></i>Version comparison</li>
            <li class="mb-2"><i class="bi bi-check-circle text-success me-2"></i>Performance metrics</li>
            <li class="mb-2"><i class="bi bi-check-circle text-success me-2"></i>Statistical analysis</li>
          </ul>
        </div>
      </div>
    </div>

    <%# Advanced Features Section %>
    <div class="col-12 mt-5">
      <h2 class="h3 mb-4">Advanced Features</h2>
    </div>

    <div class="col-md-6 col-lg-4">
      <div class="card h-100">
        <div class="card-body">
          <div class="mb-3">
            <i class="bi bi-layers fs-1 text-primary"></i>
          </div>
          <h3 class="h5 card-title">Multi-Provider Support</h3>
          <p class="card-text">
            Compatible with OpenAI (Chat, Assistants, Responses), Anthropic, Google, and more.
            Switch providers seamlessly.
          </p>
          <ul class="list-unstyled small">
            <li class="mb-2"><i class="bi bi-check-circle text-success me-2"></i>OpenAI integration</li>
            <li class="mb-2"><i class="bi bi-check-circle text-success me-2"></i>Anthropic support</li>
            <li class="mb-2"><i class="bi bi-check-circle text-success me-2"></i>Google AI</li>
            <li class="mb-2"><i class="bi bi-check-circle text-success me-2"></i>Provider abstraction</li>
          </ul>
        </div>
      </div>
    </div>

    <div class="col-md-6 col-lg-4">
      <div class="card h-100">
        <div class="card-body">
          <div class="mb-3">
            <i class="bi bi-code-slash fs-1 text-primary"></i>
          </div>
          <h3 class="h5 card-title">API Integration</h3>
          <p class="card-text">
            Integrate PromptTracker into your application with the Trackable module or
            LlmCallService for seamless tracking.
          </p>
          <ul class="list-unstyled small">
            <li class="mb-2"><i class="bi bi-check-circle text-success me-2"></i>Trackable module</li>
            <li class="mb-2"><i class="bi bi-check-circle text-success me-2"></i>Service integration</li>
            <li class="mb-2"><i class="bi bi-check-circle text-success me-2"></i>Automatic logging</li>
          </ul>
        </div>
      </div>
    </div>

    <div class="col-md-6 col-lg-4">
      <div class="card h-100">
        <div class="card-body">
          <div class="mb-3">
            <i class="bi bi-shield-check fs-1 text-success"></i>
          </div>
          <h3 class="h5 card-title">Security & Privacy</h3>
          <p class="card-text">
            Enterprise-grade security with encrypted API keys, role-based access control,
            and complete audit trails.
          </p>
          <ul class="list-unstyled small">
            <li class="mb-2"><i class="bi bi-check-circle text-success me-2"></i>Encrypted storage</li>
            <li class="mb-2"><i class="bi bi-check-circle text-success me-2"></i>Access control</li>
            <li class="mb-2"><i class="bi bi-check-circle text-success me-2"></i>Audit logs</li>
          </ul>
        </div>
      </div>
    </div>
  </div>

  <%# Call to Action %>
  <div class="row mt-5 pt-5 border-top">
    <div class="col-lg-8 mx-auto text-center">
      <h2 class="h3 mb-3">Ready to Start Tracking Your Prompts?</h2>
      <p class="text-muted mb-4">
        Create your free account and start managing, testing, and optimizing your LLM prompts today.
      </p>
      <div class="d-flex gap-3 justify-content-center flex-wrap">
        <%= link_to new_user_registration_path, class: "btn btn-primary btn-lg" do %>
          <i class="bi bi-rocket-takeoff me-2"></i>
          Get Started Free
        <% end %>
        <%= link_to root_path, class: "btn btn-outline-secondary btn-lg" do %>
          <i class="bi bi-arrow-left me-2"></i>
          Back to Home
        <% end %>
      </div>
      <p class="text-muted small mt-4">
        <i class="bi bi-check-circle text-success me-2"></i>No credit card required
        <span class="mx-2">•</span>
        <i class="bi bi-check-circle text-success me-2"></i>Free tier available
        <span class="mx-2">•</span>
        <i class="bi bi-check-circle text-success me-2"></i>100% open source
      </p>
    </div>
  </div>
</div>
