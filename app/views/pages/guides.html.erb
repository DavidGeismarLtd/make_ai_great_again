<div class="container py-5">
  <div class="row">
    <div class="col-12">
      <h1 class="mb-4">Guides & Documentation</h1>
      <p class="lead text-muted mb-5">
        Learn how to build, test, and optimize AI agents with PromptTracker
      </p>
    </div>
  </div>

  <div class="row g-4">
    <%# Getting Started Section %>
    <div class="col-12">
      <h2 class="h3 mb-4">Getting Started</h2>
    </div>

    <div class="col-md-6 col-lg-4">
      <div class="card h-100">
        <div class="card-body">
          <div class="mb-3">
            <i class="bi bi-rocket-takeoff fs-1 text-primary"></i>
          </div>
          <h3 class="h5 card-title">Quick Start Guide</h3>
          <p class="card-text">
            Get up and running with PromptTracker in minutes. Learn how to set up your account,
            connect LLM providers, and create your first agent.
          </p>
          <ul class="list-unstyled small">
            <li class="mb-2"><i class="bi bi-check-circle text-success me-2"></i>Account setup</li>
            <li class="mb-2"><i class="bi bi-check-circle text-success me-2"></i>API key configuration</li>
            <li class="mb-2"><i class="bi bi-check-circle text-success me-2"></i>First agent creation</li>
          </ul>
        </div>
      </div>
    </div>

    <div class="col-md-6 col-lg-4">
      <div class="card h-100">
        <div class="card-body">
          <div class="mb-3">
            <i class="bi bi-key fs-1 text-primary"></i>
          </div>
          <h3 class="h5 card-title">Connecting LLM Providers</h3>
          <p class="card-text">
            Learn how to connect and manage API keys for OpenAI, Anthropic, Google, Azure, and other LLM providers.
          </p>
          <ul class="list-unstyled small">
            <li class="mb-2"><i class="bi bi-check-circle text-success me-2"></i>Supported providers</li>
            <li class="mb-2"><i class="bi bi-check-circle text-success me-2"></i>API key management</li>
            <li class="mb-2"><i class="bi bi-check-circle text-success me-2"></i>Testing connections</li>
          </ul>
        </div>
      </div>
    </div>

    <div class="col-md-6 col-lg-4">
      <div class="card h-100">
        <div class="card-body">
          <div class="mb-3">
            <i class="bi bi-gear fs-1 text-primary"></i>
          </div>
          <h3 class="h5 card-title">Organization Settings</h3>
          <p class="card-text">
            Configure your organization's default settings, manage team members, and set up feature flags.
          </p>
          <ul class="list-unstyled small">
            <li class="mb-2"><i class="bi bi-check-circle text-success me-2"></i>Context defaults</li>
            <li class="mb-2"><i class="bi bi-check-circle text-success me-2"></i>Feature flags</li>
            <li class="mb-2"><i class="bi bi-check-circle text-success me-2"></i>Team management</li>
          </ul>
        </div>
      </div>
    </div>

    <%# Creating Agents Section %>
    <div class="col-12 mt-5">
      <h2 class="h3 mb-4">Creating AI Agents</h2>
    </div>

    <div class="col-md-6 col-lg-4">
      <div class="card h-100 border-primary">
        <div class="card-body">
          <div class="mb-3">
            <i class="bi bi-robot fs-1 text-primary"></i>
          </div>
          <h3 class="h5 card-title">Agent Development Basics</h3>
          <p class="card-text">
            Master the fundamentals of creating AI agents. Learn about prompts, system messages,
            tools, and configuration options.
          </p>
          <ul class="list-unstyled small">
            <li class="mb-2"><i class="bi bi-check-circle text-success me-2"></i>Prompt engineering</li>
            <li class="mb-2"><i class="bi bi-check-circle text-success me-2"></i>System messages</li>
            <li class="mb-2"><i class="bi bi-check-circle text-success me-2"></i>Tool configuration</li>
            <li class="mb-2"><i class="bi bi-check-circle text-success me-2"></i>Model selection</li>
          </ul>
        </div>
      </div>
    </div>

    <div class="col-md-6 col-lg-4">
      <div class="card h-100">
        <div class="card-body">
          <div class="mb-3">
            <i class="bi bi-git fs-1 text-primary"></i>
          </div>
          <h3 class="h5 card-title">Version Control</h3>
          <p class="card-text">
            Track changes to your agents over time. Learn how to use version control to manage
            iterations and roll back when needed.
          </p>
          <ul class="list-unstyled small">
            <li class="mb-2"><i class="bi bi-check-circle text-success me-2"></i>Version history</li>
            <li class="mb-2"><i class="bi bi-check-circle text-success me-2"></i>Rollback capabilities</li>
            <li class="mb-2"><i class="bi bi-check-circle text-success me-2"></i>Change tracking</li>
          </ul>
        </div>
      </div>
    </div>

    <div class="col-md-6 col-lg-4">
      <div class="card h-100">
        <div class="card-body">
          <div class="mb-3">
            <i class="bi bi-layers fs-1 text-primary"></i>
          </div>
          <h3 class="h5 card-title">Multi-LLM Support</h3>
          <p class="card-text">
            Use the same agent configuration across different LLM providers. Compare performance
            and costs between providers.
          </p>
          <ul class="list-unstyled small">
            <li class="mb-2"><i class="bi bi-check-circle text-success me-2"></i>Provider switching</li>
            <li class="mb-2"><i class="bi bi-check-circle text-success me-2"></i>Cross-provider testing</li>
            <li class="mb-2"><i class="bi bi-check-circle text-success me-2"></i>Performance comparison</li>
          </ul>
        </div>
      </div>
    </div>

    <%# Testing Section %>
    <div class="col-12 mt-5">
      <h2 class="h3 mb-4">Agent Testing</h2>
    </div>

    <div class="col-md-6 col-lg-4">
      <div class="card h-100 border-primary">
        <div class="card-body">
          <div class="mb-3">
            <i class="bi bi-check2-square fs-1 text-primary"></i>
          </div>
          <h3 class="h5 card-title">Automated Testing</h3>
          <p class="card-text">
            Create and run automated test suites for your agents. Ensure reliability and catch
            issues before they reach production.
          </p>
          <ul class="list-unstyled small">
            <li class="mb-2"><i class="bi bi-check-circle text-success me-2"></i>Test suite creation</li>
            <li class="mb-2"><i class="bi bi-check-circle text-success me-2"></i>Test case design</li>
            <li class="mb-2"><i class="bi bi-check-circle text-success me-2"></i>Automated execution</li>
            <li class="mb-2"><i class="bi bi-check-circle text-success me-2"></i>Regression testing</li>
          </ul>
        </div>
      </div>
    </div>

    <div class="col-md-6 col-lg-4">
      <div class="card h-100 border-primary">
        <div class="card-body">
          <div class="mb-3">
            <i class="bi bi-clipboard-data fs-1 text-primary"></i>
          </div>
          <h3 class="h5 card-title">Test Datasets</h3>
          <p class="card-text">
            Build comprehensive test datasets to validate agent behavior across different scenarios
            and edge cases.
          </p>
          <ul class="list-unstyled small">
            <li class="mb-2"><i class="bi bi-check-circle text-success me-2"></i>Dataset creation</li>
            <li class="mb-2"><i class="bi bi-check-circle text-success me-2"></i>Test case management</li>
            <li class="mb-2"><i class="bi bi-check-circle text-success me-2"></i>Expected outputs</li>
            <li class="mb-2"><i class="bi bi-check-circle text-success me-2"></i>Edge case testing</li>
          </ul>
        </div>
      </div>
    </div>

    <div class="col-md-6 col-lg-4">
      <div class="card h-100">
        <div class="card-body">
          <div class="mb-3">
            <i class="bi bi-shuffle fs-1 text-primary"></i>
          </div>
          <h3 class="h5 card-title">A/B Testing</h3>
          <p class="card-text">
            Compare different agent configurations side-by-side. Make data-driven decisions about
            which approach works best.
          </p>
          <ul class="list-unstyled small">
            <li class="mb-2"><i class="bi bi-check-circle text-success me-2"></i>Configuration comparison</li>
            <li class="mb-2"><i class="bi bi-check-circle text-success me-2"></i>Performance metrics</li>
            <li class="mb-2"><i class="bi bi-check-circle text-success me-2"></i>Statistical analysis</li>
          </ul>
        </div>
      </div>
    </div>

    <div class="col-md-6 col-lg-4">
      <div class="card h-100">
        <div class="card-body">
          <div class="mb-3">
            <i class="bi bi-speedometer2 fs-1 text-primary"></i>
          </div>
          <h3 class="h5 card-title">Performance Evaluation</h3>
          <p class="card-text">
            Measure and analyze agent performance. Track metrics like accuracy, latency, and cost
            to optimize your agents.
          </p>
          <ul class="list-unstyled small">
            <li class="mb-2"><i class="bi bi-check-circle text-success me-2"></i>Quality metrics</li>
            <li class="mb-2"><i class="bi bi-check-circle text-success me-2"></i>Latency tracking</li>
            <li class="mb-2"><i class="bi bi-check-circle text-success me-2"></i>Cost analysis</li>
          </ul>
        </div>
      </div>
    </div>

    <div class="col-md-6 col-lg-4">
      <div class="card h-100">
        <div class="card-body">
          <div class="mb-3">
            <i class="bi bi-bug fs-1 text-primary"></i>
          </div>
          <h3 class="h5 card-title">Debugging & Troubleshooting</h3>
          <p class="card-text">
            Learn how to debug agent issues using detailed logs, trace data, and diagnostic tools.
          </p>
          <ul class="list-unstyled small">
            <li class="mb-2"><i class="bi bi-check-circle text-success me-2"></i>Log analysis</li>
            <li class="mb-2"><i class="bi bi-check-circle text-success me-2"></i>Trace inspection</li>
            <li class="mb-2"><i class="bi bi-check-circle text-success me-2"></i>Error handling</li>
          </ul>
        </div>
      </div>
    </div>

    <%# Best Practices Section %>
    <div class="col-12 mt-5">
      <h2 class="h3 mb-4">Best Practices</h2>
    </div>

    <div class="col-md-6 col-lg-4">
      <div class="card h-100">
        <div class="card-body">
          <div class="mb-3">
            <i class="bi bi-lightbulb fs-1 text-warning"></i>
          </div>
          <h3 class="h5 card-title">Prompt Engineering Tips</h3>
          <p class="card-text">
            Learn proven techniques for writing effective prompts that produce consistent,
            high-quality results.
          </p>
        </div>
      </div>
    </div>

    <div class="col-md-6 col-lg-4">
      <div class="card h-100">
        <div class="card-body">
          <div class="mb-3">
            <i class="bi bi-shield-check fs-1 text-success"></i>
          </div>
          <h3 class="h5 card-title">Security Best Practices</h3>
          <p class="card-text">
            Protect your API keys, manage access controls, and follow security best practices
            for production deployments.
          </p>
        </div>
      </div>
    </div>

    <div class="col-md-6 col-lg-4">
      <div class="card h-100">
        <div class="card-body">
          <div class="mb-3">
            <i class="bi bi-cash-coin fs-1 text-info"></i>
          </div>
          <h3 class="h5 card-title">Cost Optimization</h3>
          <p class="card-text">
            Strategies for reducing LLM API costs while maintaining quality. Learn about caching,
            model selection, and efficient prompting.
          </p>
        </div>
      </div>
    </div>
  </div>

  <%# Call to Action %>
  <div class="row mt-5 pt-5 border-top">
    <div class="col-lg-8 mx-auto text-center">
      <h2 class="h3 mb-3">Ready to Get Started?</h2>
      <p class="text-muted mb-4">
        Create your free account and start building production-ready AI agents today.
      </p>
      <div class="d-flex gap-3 justify-content-center">
        <%= link_to "Get Started Free", new_user_registration_path, class: "btn btn-primary btn-lg" %>
        <%= link_to "← Back to Home", root_path, class: "btn btn-outline-secondary btn-lg" %>
      </div>
    </div>
  </div>
</div>
